# Copy to .env.local for local dev, and set the same in Vercel project settings.

# Neon Postgres (pooled connection string from the Neon dashboard)
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/reservoirlovers?sslmode=require

# Strava app credentials (strava.com/settings/api)
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Any random string you choose; Strava echoes it during webhook validation
STRAVA_WEBHOOK_VERIFY_TOKEN=pick-any-random-string

# 32-byte base64 key for encrypting Strava tokens at rest:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# >=32 char secret for signing the session cookie:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Public origin of the site (no trailing slash)
SITE_URL=https://reservoirlovers.nyc

# Strava segment whose polyline seeds the canonical loop geometry (used once by
# `npm run build:loop`). Defaults to 852256, the "Central Park Reservoir Loop".
# Direction doesn't matter — the matcher counts loops from any start/direction.
RESERVOIR_SEGMENT_ID=852256

# Optional: a Strava access token for `npm run build:loop` to fetch the segment
# polyline (grab one from your app's API settings page). If unset, the script
# falls back to a connected user's token from the DB.
# STRAVA_ACCESS_TOKEN=

# Your Strava athlete id — gets access to /admin (the invite manager)
ADMIN_ATHLETE_ID=

# Random secret; Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=
