{
  "name": "reservoirlovers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:loop": "tsx --env-file-if-exists=.env.local scripts/build-canonical-loop.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/migrate.ts",
    "backfill": "tsx --env-file-if-exists=.env.local scripts/backfill.ts",
    "invites:release": "tsx --env-file-if-exists=.env.local scripts/release-orphan-invites.ts",
    "invites:purge": "tsx --env-file-if-exists=.env.local scripts/purge-open-invites.ts",
    "secret:rotate": "tsx scripts/rotate-session-secret.ts",
    "webhook:subscribe": "tsx --env-file-if-exists=.env.local scripts/webhook-subscribe.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@vercel/functions": "^2.0.0",
    "drizzle-orm": "^0.38.3",
    "iron-session": "^8.0.4",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
